{
  "buildCommand": "npm install -g pnpm@9 && pnpm install --frozen-lockfile && pnpm --filter @workspace/admin-dashboard run build",
  "outputDirectory": "artifacts/admin-dashboard/dist/public",
  "installCommand": "npm install -g pnpm@9 && pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
