{
  "buildCommand": "NODE_ENV=development npx pnpm@9 install --no-frozen-lockfile && npx pnpm@9 --filter @workspace/admin-dashboard run build",
  "outputDirectory": "artifacts/admin-dashboard/dist/public",
  "installCommand": "echo skip",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
